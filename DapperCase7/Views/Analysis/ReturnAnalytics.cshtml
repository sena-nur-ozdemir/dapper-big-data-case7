@using System.Text.Json
@model List<DapperCase7.Dtos.DashboardDtos.ReturnAnalyticsDto>
@{
    ViewData["Title"] = "İade & Risk Paneli";
    ViewData["ActivePage"] = "ReturnAnalytics";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Riski hesaplamak için en yüksek iade sayısını buluyoruz
    int maxReturn = Model.Any() ? Model.Max(x => x.ReturnedCount) : 1;
}

<div class="row g-4">
    <div class="col-xl-7 col-lg-6">
        <div class="chart-card" style="background:var(--surface-1); border:1px solid rgba(241, 65, 108, 0.5); border-radius:16px; box-shadow: 0 0 20px rgba(241, 65, 108, 0.05);">
            <div class="chart-header" style="padding:20px; border-bottom:1px solid rgba(241, 65, 108, 0.2);">
                <h5 style="color:var(--text-primary); font-weight:700; margin:0;">
                    <i class="fa-solid fa-triangle-exclamation fa-fade" style="color:var(--accent-red);"></i> Kritik Risk Taşıyan Merkezler
                </h5>
                <div style="color:var(--text-secondary); font-size:11px; margin-top:4px;">Durumu "İade" olan kargoların yoğunluk analizi</div>
            </div>

            <div class="chart-body" style="padding:20px;">
                @foreach (var item in Model)
                {
                    // Risk seviyesine göre renk ve etiket belirliyoruz
                    int riskLevel = (int)((double)item.ReturnedCount / maxReturn * 100);
                    string riskClass = riskLevel > 70 ? "KRİTİK RİSK" : "YÜKSEK RİSK";
                    string riskColor = riskLevel > 70 ? "var(--accent-red)" : "var(--accent-amber)";
                    string bgGlow = riskLevel > 70 ? "rgba(241, 65, 108, 0.08)" : "var(--surface-2)";

                    <div style="background:@bgGlow; border-left:4px solid @riskColor; border-radius:8px; padding:15px 20px; margin-bottom:15px; display:flex; justify-content:space-between; align-items:center; transition: transform 0.2s;" class="risk-card">
                        <div>
                            <div style="color:#fff; font-size:16px; font-weight:700; letter-spacing:0.5px;">@item.CityName</div>
                            <div style="color:@riskColor; font-size:11px; margin-top:4px; font-weight:700;">
                                <i class="fa-solid fa-circle-radiation"></i> @riskClass
                            </div>
                        </div>
                        <div style="text-align:right;">
                            <div style="color:@riskColor; font-size:24px; font-weight:800; line-height:1;">@item.ReturnedCount.ToString("N0")</div>
                            <div style="color:var(--text-muted); font-size:10px; text-transform:uppercase; font-weight:700; margin-top:4px;">İade Edilen Paket</div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-xl-5 col-lg-6">
        <div class="chart-card" style="background:var(--surface-1); border:1px solid var(--border-color); border-radius:16px; height:100%; display:flex; flex-direction:column;">
            <div class="chart-header" style="padding:20px; border-bottom:1px solid var(--border-color);">
                <h5 style="color:var(--text-primary); font-weight:700; margin:0;">
                    <i class="fa-solid fa-bullseye" style="color:var(--accent-amber);"></i> Risk Ayak İzi
                </h5>
            </div>
            <div class="chart-body" style="padding:20px; flex:1; display:flex; align-items:center; justify-content:center; position:relative;">
                <canvas id="riskChart" style="max-height: 350px;"></canvas>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const rawData = @Html.Raw(JsonSerializer.Serialize(Model));
            const labels = rawData.map(x => x.CityName);
            const data = rawData.map(x => x.ReturnedCount);

            new Chart(document.getElementById('riskChart'), {
                type: 'polarArea', // Çok teknolojik ve havalı duran kutup grafiği
                data: {
                    labels: labels,
                    datasets: [{
                        data: data,
                        backgroundColor: [
                            'rgba(241, 65, 108, 0.8)', /* Kırmızı (En Yüksek Risk) */
                            'rgba(241, 65, 108, 0.5)',
                            'rgba(255, 199, 0, 0.7)',  /* Sarı (Orta Risk) */
                            'rgba(255, 199, 0, 0.4)',
                            'rgba(0, 158, 247, 0.4)'   /* Mavi (Düşük Risk) */
                        ],
                        borderColor: '#181818',
                        borderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        r: {
                            ticks: { display: false }, /* İçteki sayıları gizle */
                            grid: { color: 'rgba(255,255,255,0.05)' }, /* Örümcek ağı çizgileri */
                            angleLines: { color: 'rgba(255,255,255,0.05)' }
                        }
                    },
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: { color: '#a1a5b7', font: { size: 12 }, usePointStyle: true, padding: 20 }
                        },
                        tooltip: {
                            backgroundColor: '#1e1e2d',
                            titleColor: '#fff',
                            bodyColor: '#f1416c',
                            borderColor: '#323248',
                            borderWidth: 1,
                            padding: 12,
                            callbacks: {
                                label: function(context) {
                                    return ' ' + context.parsed.toLocaleString('tr-TR') + ' İade Paketi';
                                }
                            }
                        }
                    }
                }
            });
        });
    </script>

    <style>
        .risk-card:hover {
            transform: translateX(5px);
            box-shadow: -5px 0 15px rgba(241, 65, 108, 0.15);
        }
    </style>
}