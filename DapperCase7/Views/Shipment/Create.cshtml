@model DapperCase7.Dtos.ShipmentDtos.CreateShipmentDto

@{
    ViewData["Title"] = "Yeni Kargo Ekle";
    ViewData["ActivePage"] = "CreateShipment";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row">
    <div class="col-xl-6 col-lg-8">
        <div class="chart-card" style="background:var(--surface-1); border:1px solid var(--border-color); border-radius:16px;">
            <div class="chart-header" style="padding:20px; border-bottom:1px solid var(--border-color);">
                <h5 style="color:var(--text-primary); font-weight:700; font-size:16px; margin:0;">
                    <i class="fa-solid fa-box-open" style="color:var(--accent-teal);"></i> Sisteme Yeni Kargo Gir
                </h5>
                <div style="color:var(--text-secondary); font-size:12px; margin-top:4px;">
                    Takip numarası ve kayıt tarihi sistem tarafından otomatik atanacaktır.
                </div>
            </div>

            <div class="chart-body" style="padding:30px;">
                <form method="post" action="/Shipment/Create">

                    <div class="mb-4">
                        <label style="color:var(--text-secondary); font-size:12px; font-weight:600; margin-bottom:8px;">ÇIKIŞ İLİ (Gönderici)</label>
                        <input type="text" asp-for="SenderCity" required placeholder="Örn: İstanbul" class="form-control" style="background:var(--surface-2); border:1px solid var(--border-color); color:var(--text-primary); border-radius:8px;" />
                    </div>

                    <div class="mb-4">
                        <label style="color:var(--text-secondary); font-size:12px; font-weight:600; margin-bottom:8px;">VARIŞ İLİ (Alıcı)</label>
                        <input type="text" asp-for="ReceiverCity" required placeholder="Örn: Ankara" class="form-control" style="background:var(--surface-2); border:1px solid var(--border-color); color:var(--text-primary); border-radius:8px;" />
                    </div>

                    <div class="mb-4">
                        <label style="color:var(--text-secondary); font-size:12px; font-weight:600; margin-bottom:8px;">TAHSİLAT ÜCRETİ (₺)</label>
                        <input type="number" step="0.01" asp-for="Price" required placeholder="0.00" class="form-control" style="background:var(--surface-2); border:1px solid var(--border-color); color:var(--accent-teal); font-weight:700; border-radius:8px;" />
                    </div>

                    <div style="display:flex; gap:12px; margin-top:20px;">
                        <button type="submit" class="btn" style="background:var(--accent-teal); color:#000; font-weight:700; border-radius:8px; padding:10px 24px;">
                            <i class="fa-solid fa-check"></i> Kargoyu Oluştur
                        </button>
                        <a href="/Shipment/Index" class="btn" style="background:transparent; border:1px solid var(--border-color); color:var(--text-secondary); font-weight:600; border-radius:8px; padding:10px 24px;">
                            İptal
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>