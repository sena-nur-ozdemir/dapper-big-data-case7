@model List<DapperCase7.Dtos.ShipmentDtos.ShipmentListDto>

@{
    ViewData["Title"] = "Kargo Operasyon Listesi";
    ViewData["ActivePage"] = "Shipment";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row mb-4">
    <div class="col-12">
        <div class="chart-card" style="background:var(--surface-1); border:1px solid var(--border-color); border-radius:16px; overflow:hidden;">

            <div class="chart-header" style="padding:20px; border-bottom:1px solid var(--border-color); display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:16px;">
                <div>
                    <h5 style="color:var(--text-primary); font-weight:700; font-size:16px; margin:0;">
                        <i class="fa-solid fa-boxes-stacked" style="color:var(--accent-blue);"></i> Canlı Lojistik Kayıtları
                    </h5>
                    <div style="color:var(--text-secondary); font-size:12px; margin-top:4px;">
                        Bulunan Kayıt: <strong style="color:var(--accent-teal);">@ViewBag.TotalCount.ToString("N0")</strong> Kargo
                    </div>
                </div>

                <div style="display:flex; gap:12px; align-items:center;">
                    <form method="get" action="/Shipment/Index" style="display:flex; gap:8px; margin:0;">
                        <input type="text" name="searchTrackNo" value="@ViewBag.SearchTrackNo" placeholder="Takip No (Örn: LF-200)..." class="form-control" style="background:var(--surface-2); border:1px solid var(--border-color); color:var(--text-primary); border-radius:8px; font-size:13px; width:220px;" />
                        <button type="submit" class="btn" style="background:var(--surface-2); color:var(--text-secondary); border:1px solid var(--border-color); border-radius:8px; padding:6px 12px;">
                            <i class="fa-solid fa-magnifying-glass"></i>
                        </button>
                        @if (!string.IsNullOrEmpty(ViewBag.SearchTrackNo))
                        {
                            <a href="/Shipment/Index" class="btn" style="background:var(--surface-2); color:var(--accent-red); border:1px solid var(--border-color); border-radius:8px; padding:6px 12px;" title="Aramayı Temizle">
                                <i class="fa-solid fa-xmark"></i>
                            </a>
                        }
                    </form>

                    <a href="/Shipment/Create" class="btn btn-primary" style="background:var(--accent-blue); border:none; font-size:13px; font-weight:600; padding:8px 16px; border-radius:8px;">
                        <i class="fa-solid fa-plus"></i> Yeni Kayıt
                    </a>
                </div>
            </div>

            <div class="table-responsive" style="padding:10px 20px;">
                <table class="table table-dark-custom" style="width:100%; margin-bottom:0;">
                    <thead>
                        <tr>
                            <th style="color:#5e6278; font-size:11px; padding:12px 10px; border-bottom:1px dashed var(--border-color);">TAKİP NO</th>
                            <th style="color:#5e6278; font-size:11px; padding:12px 10px; border-bottom:1px dashed var(--border-color);">ÇIKIŞ İLİ</th>
                            <th style="color:#5e6278; font-size:11px; padding:12px 10px; border-bottom:1px dashed var(--border-color);">VARIŞ İLİ</th>
                            <th style="color:#5e6278; font-size:11px; padding:12px 10px; border-bottom:1px dashed var(--border-color);">TARİH</th>
                            <th style="color:#5e6278; font-size:11px; padding:12px 10px; border-bottom:1px dashed var(--border-color);">ÜCRET</th>
                            <th style="color:#5e6278; font-size:11px; padding:12px 10px; border-bottom:1px dashed var(--border-color);">DURUM</th>
                            <th style="color:#5e6278; font-size:11px; padding:12px 10px; border-bottom:1px dashed var(--border-color); text-align:right;">İŞLEMLER</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr style="border-bottom:1px dashed var(--border-color); transition: background 0.2s;">
                                <td style="padding:14px 10px; font-family:'JetBrains Mono', monospace; font-weight:700; color:var(--accent-blue);">@item.TrackingNumber</td>
                                <td style="padding:14px 10px; color:var(--text-primary); font-size:13px;">@item.SenderCity</td>
                                <td style="padding:14px 10px; color:var(--text-primary); font-size:13px;">@item.ReceiverCity</td>
                                <td style="padding:14px 10px; color:var(--text-secondary); font-size:12px;">@item.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                <td style="padding:14px 10px; font-weight:700; color:var(--accent-teal); font-size:13px;">₺@item.Price.ToString("N2")</td>
                                <td style="padding:14px 10px;">
                                    @if (item.ShipmentStatus == 1)
                                    {
                                        <span class="badge" style="background:rgba(0, 200, 255, 0.12); color:#00c8ff; border:1px solid rgba(0,200,255,0.25);">Hazırlanıyor</span>
                                    }
                                    else if (item.ShipmentStatus == 2)
                                    {

                                        <span class="badge" style="background:rgba(26, 107, 255, 0.12); color:#4d8dff; border:1px solid rgba(26,107,255,0.25);">Yolda</span>
                                    }
                                    else if (item.ShipmentStatus == 3)
                                    {

                                        <span class="badge" style="background:rgba(255, 176, 32, 0.12); color:#ffb020; border:1px solid rgba(255,176,32,0.25);">Dağıtımda</span>
                                    }
                                    else if (item.ShipmentStatus == 4)
                                    {

                                        <span class="badge" style="background:rgba(32, 212, 137, 0.12); color:#20d489; border:1px solid rgba(32,212,137,0.25);">Teslim Edildi</span>
                                    }
                                    else
                                    {

                                        <span class="badge" style="background:rgba(241, 65, 108, 0.12); color:#f1416c; border:1px solid rgba(241,65,108,0.25);">İade</span>
                                    }
                                </td>
                                <td style="padding:14px 10px; text-align:right;">
                                    <a href="/Shipment/Update/@item.Id" class="btn btn-sm" style="background:var(--surface-2); color:var(--accent-blue); border:1px solid var(--border-color); padding:4px 8px; font-size:12px;"><i class="fa-solid fa-pen-to-square"></i></a>
                                    <a href="/Shipment/Delete/@item.Id" onclick="confirmDelete(event, this.href);" class="btn btn-sm" style="background:var(--surface-2); color:var(--accent-red); border:1px solid var(--border-color); padding:4px 8px; font-size:12px;"><i class="fa-solid fa-trash"></i></a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div style="padding:16px 20px; border-top:1px solid var(--border-color); display:flex; justify-content:space-between; align-items:center;">
                <div style="color:var(--text-secondary); font-size:13px;">
                    Sayfa <strong style="color:var(--text-primary);">@ViewBag.CurrentPage</strong> / @ViewBag.TotalPages.ToString("#,##0").Replace(',', '.')
                </div>

                <div style="display:flex; gap:6px;">
                    @if (ViewBag.CurrentPage > 1)
                    {
                        <a href="/Shipment/Index?page=@(ViewBag.CurrentPage - 1)" class="btn btn-sm" style="background:var(--surface-2); color:var(--text-secondary); border:1px solid var(--border-color);">
                            <i class="fa-solid fa-chevron-left"></i> Önceki
                        </a>
                    }

                    @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                    {
                        <a href="/Shipment/Index?page=@(ViewBag.CurrentPage + 1)" class="btn btn-sm" style="background:var(--accent-blue); color:#fff; border:1px solid var(--accent-blue);">
                            Sonraki <i class="fa-solid fa-chevron-right"></i>
                        </a>
                    }
                </div>
            </div>

        </div>
    </div>
</div>