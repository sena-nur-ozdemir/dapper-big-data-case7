@model DapperCase7.Dtos.DashboardDtos.KpiCardDto

<div class="row g-3 mb-4">
    <div class="col-xl-3 col-lg-6 col-sm-6">
        <div class="kpi-card kpi-blue">
            <div class="kpi-icon kpi-icon-blue" style="background:rgba(0,158,247,0.15); color:#009ef7; width:44px; height:44px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:18px; margin-bottom:14px;"><i class="fa-solid fa-boxes-stacked"></i></div>
            <div class="kpi-value">@Model.TotalShipments.ToString("N0")</div>
            <div class="kpi-label">TOPLAM KARGO HACMİ</div>
            <div class="kpi-change up" style="color:#20d489; font-size:12px; font-weight:600; margin-top:10px;"><i class="fa-solid fa-database"></i> 1.000.000 Satır Aktif Veri</div>
        </div>
    </div>

    <div class="col-xl-3 col-lg-6 col-sm-6">
        <div class="kpi-card kpi-green">
            <div class="kpi-icon kpi-icon-green" style="background:rgba(32,212,137,0.15); color:#20d489; width:44px; height:44px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:18px; margin-bottom:14px;"><i class="fa-solid fa-wallet"></i></div>
            <div class="kpi-value">₺@Model.TotalRevenue.ToString("N2")</div>
            <div class="kpi-label">TOPLAM LOJİSTİK CİROSU</div>
            <div class="kpi-change up" style="color:#20d489; font-size:12px; font-weight:600; margin-top:10px;"><i class="fa-solid fa-arrow-trend-up"></i> Tüm Operasyon Toplamı</div>
        </div>
    </div>

    <div class="col-xl-3 col-lg-6 col-sm-6">
        <div class="kpi-card kpi-teal">
            <div class="kpi-icon kpi-icon-teal" style="background:rgba(0,229,180,0.15); color:#00e5b4; width:44px; height:44px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:18px; margin-bottom:14px;"><i class="fa-solid fa-truck-ramp-box"></i></div>
            <div class="kpi-value">@Model.DeliveredCount.ToString("N0")</div>
            <div class="kpi-label">TESLİM EDİLEN PAKET</div>
            <div class="kpi-change up" style="color:#00e5b4; font-size:12px; font-weight:600; margin-top:10px;"><i class="fa-solid fa-check-double"></i> Başarı Oranı Yüksek</div>
        </div>
    </div>

    <div class="col-xl-3 col-lg-6 col-sm-6">
        <div class="kpi-card kpi-amber">
            <div class="kpi-icon kpi-icon-amber" style="background:rgba(255,199,0,0.15); color:#ffc700; width:44px; height:44px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:18px; margin-bottom:14px;"><i class="fa-solid fa-route"></i></div>
            <div class="kpi-value">@Model.InTransitCount.ToString("N0")</div>
            <div class="kpi-label">DAĞITIMDA & YOLDA</div>
            <div class="kpi-change up" style="color:#ffc700; font-size:12px; font-weight:600; margin-top:10px;"><i class="fa-solid fa-clock"></i> Anlık Transfer Akışı</div>
        </div>
    </div>
</div>